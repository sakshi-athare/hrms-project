{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "types": ["vite/client"],
    "skipLibCheck": true,
    "noEmit": true,

    "strict": true,

    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": ["src"]
}